# ------------------------------
# DATABASE CONFIGURATION
# ------------------------------
# The hostname or IP address of your live database server.
DB_HOST=127.0.0.1
# The port your database is running on (3306 is the default for MySQL).
DB_PORT=3306
# The username for connecting to your database.
DB_USERNAME=root
# The password for the database user. This is highly sensitive.
DB_PASSWORD=
# The name of the database the application should connect to.
DB_DATABASE=saaslink

# ------------------------------
# APPLICATION SECURITY
# ------------------------------
# A long, random, and secret string (at least 32 characters) used to sign authentication tokens.
JWT_SECRET=dev_secret_key_at_least_32_characters_long_for_safety

# ------------------------------
# STRIPE PAYMENT INTEGRATION
# ------------------------------
# Your Stripe secret key. Found in your Stripe dashboard (e.g., sk_live_...).
STRIPE_SECRET_KEY=
# Your Stripe publishable key. Found in your Stripe dashboard (e.g., pk_live_...).
REACT_APP_STRIPE_PUBLISHABLE_KEY=
