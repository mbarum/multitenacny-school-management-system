# ====================================================================
#          SAASLINK - ENVIRONMENT VARIABLES TEMPLATE
# ====================================================================
#
# This file defines all the environment variables required to run the
# application. Copy this file to .env for local development and fill
# in the values for your environment.

# --------------------------------------------------------------------
# CORE APPLICATION CONFIGURATION
# --------------------------------------------------------------------

# Secure key for signing JWT tokens. Use a long, random string.
JWT_SECRET=

# The public URL of your frontend application.
# Used for generating links in emails and other services.
FRONTEND_URL=http://localhost:3000

# --------------------------------------------------------------------
# DATABASE (MySQL)
# --------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# --------------------------------------------------------------------
# STRIPE PAYMENT GATEWAY (for Card Payments)
# --------------------------------------------------------------------

# Your Stripe secret key (for backend use).
VITE_STRIPE_PUBLISHABLE_KEY=

# Your Stripe publishable key (for frontend use).
STRIPE_SECRET_KEY=

# Your Stripe webhook signing secret.
# Used to verify webhook events from Stripe.
STRIPE_WEBHOOK_SECRET=

# --------------------------------------------------------------------
# SAFARICOM DARAJA API (for M-Pesa Payments)
# --------------------------------------------------------------------

# Found on the Safaricom Developer Portal.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Your M-Pesa PayBill or Till Number.
MPESA_SHORTCODE=

# The Lipa Na M-Pesa Online Passkey.
MPESA_PASSKEY=

# The callback URL for receiving payment notifications from Daraja.
# e.g., https://your-production-domain.com/api/mpesa/stk-push-callback
MPESA_CALLBACK_URL=

# --------------------------------------------------------------------
# EMAIL (SMTP)
# --------------------------------------------------------------------

# Your SMTP server host (e.g., smtp.gmail.com).
EMAIL_HOST=

# Your SMTP server port (e.g., 587).
EMAIL_PORT=

# Your SMTP username.
EMAIL_USER=

# Your SMTP password or app-specific password.
EMAIL_PASS=

# The 'From' address for outgoing emails.
EMAIL_FROM=

