# Application - The base URL of this application
APP_URL=http://localhost:3000

# JWT Secret - A long, random string used to sign session tokens
JWT_SECRET=

# --- Identity Provider Credentials ---

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Azure AD
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# This is the 'Directory (tenant) ID' from your Azure AD App Registration
AZURE_TENANT_ID=

# Okta
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
# e.g., https://dev-123456.okta.com
OKTA_ISSUER=
